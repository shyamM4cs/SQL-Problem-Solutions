ELECT output
FROM (
    SELECT CONCAT(name, '(', LEFT(occupation, 1), ')') AS output, 1 AS sort_order
    FROM OCCUPATIONS
    
    UNION ALL
    
    SELECT CONCAT('There are a total of ', COUNT(*), ' ', LOWER(occupation), 's.') AS output,
           2 AS sort_order
    FROM OCCUPATIONS
    GROUP BY occupation
) t
ORDER BY sort_order, output;
